# Copy to .env and fill in. Never commit .env.

# LLM (OpenAI) — used by the clause parser
OPENAI_API_KEY=
LLM_MODEL=gpt-4o

# Prediction-market data sources
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
POLYMARKET_CLOB_URL=https://clob.polymarket.com

# Service
APP_ENV=dev
DATABASE_URL=sqlite:///./resolution_layer.db

# Admin bearer for POST /admin/keys (minting API keys).
# Leave empty in local dev (admin route is open); MUST be set in production.
ADMIN_TOKEN=

# x402 pay-per-call (Phase 3). Off by default => endpoint is FREE.
# The ASP registers on OKX as free (fee "0") first; this layer stays dormant
# until we choose to charge. Turn on + simulate to exercise the handshake.
X402_ENABLED=false
X402_MODE=simulate                 # simulate | live
X402_PRICE_USDT=0.05               # price per call, human units
X402_PAY_TO=                       # seller receiving address (required when live)
X402_NETWORK=eip155:196            # X Layer mainnet
X402_ASSET=0x779Ded0c9e1022225f8E0630b35a9b54bE713736   # USDT0
X402_ASSET_DECIMALS=6
X402_MAX_TIMEOUT_SECONDS=120
OKX_BASE_URL=https://www.web3.okx.com   # x402 facilitator base

# Oracle monitor (Phase 4). Off by default so dev/tests don't spawn the poller.
MONITOR_ENABLED=false
MONITOR_INTERVAL_SECONDS=300
MONITOR_WEBHOOK_TIMEOUT_SECONDS=10

# Redis (Phase 7). Empty => caching, rate-limiting, and pub/sub all no-op.
# The service runs identically without Redis, just uncached/unthrottled.
REDIS_URL=
CACHE_MARKET_TTL_SECONDS=3600      # raw market/oracle data cache
CACHE_EVAL_TTL_SECONDS=900         # LLM audit output cache
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60           # per API key (needs Redis to enforce)

# Telegram bot (Phase 6)
TELEGRAM_BOT_TOKEN=
